{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "files": {},
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": { "useExhaustiveDependencies": "warn" }
    }
  },
  "javascript": {
    "formatter": { "jsxQuoteStyle": "double", "quoteStyle": "double" },
    "jsxRuntime": "reactClassic"
  }
}
