# ─────────────────────────────────────────────
#  Foresight — environment variables
#  Copy to .env.local and fill in your values.
#  Variables prefixed NEXT_PUBLIC_* are exposed
#  to the browser bundle.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
# Public URL of this deployment (used for OG images, manifests, SIWE)
NEXT_PUBLIC_URL=https://foresight-apps.vercel.app

# Base App ID issued via developer.base.org (optional — enables Base wallet features)
NEXT_PUBLIC_BASE_APP_ID=

# ── Backend API ───────────────────────────────
# Root URL of the Foresight alpha-intelligence API.
# When omitted, every page falls back to mock data automatically.
NEXT_PUBLIC_API_URL=https://api.foresight.xyz

# ── RPC ──────────────────────────────────────
# Base mainnet JSON-RPC endpoint (optional — defaults to https://mainnet.base.org)
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org

# ── Push notifications (Upstash Redis) ───────
# Required only for the /api/webhook and /api/notify routes.
# Provision a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
